# Crowdin sync config. Translations land next to the English source as
# `<page>.<locale>.md`, which mkdocs-static-i18n serves per language.
# `languages_mapping` rewrites Crowdin's language ids to the codes
# mkdocs-material supports (es, zh) so its UI strings resolve.
preserve_hierarchy: true

files:
  - source: /docs/**/*.md
    ignore:
      - "/docs/**/*.pt-BR.md"
      - "/docs/**/*.es.md"
      - "/docs/**/*.ja.md"
      - "/docs/**/*.zh.md"
      - "/docs/**/*.zh-TW.md"
    translation: "/%original_path%/%file_name%.%locale%.%file_extension%"
    languages_mapping:
      locale:
        es-ES: es
        es-419: es
        zh-CN: zh
