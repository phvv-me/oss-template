# Single source of truth for how docs sync with Crowdin (read by the GitHub
# integration). Only project-level settings Crowdin cannot read from a file
# stay in the web UI, one time: TARGET LANGUAGES, machine translation, and the
# glossary (terms live in i18n/glossary.csv here; import them once).
preserve_hierarchy: true

# Title of the translation PR Crowdin opens against the base branch.
pull_request_title: "New translations from Crowdin"

files:
  - source: /docs/**/*.md
    # Don't re-upload already-translated pages as new sources.
    ignore:
      - "/docs/**/*.pt-BR.md"
      - "/docs/**/*.es.md"
      - "/docs/**/*.ja.md"
      - "/docs/**/*.zh.md"
      - "/docs/**/*.zh-TW.md"
    translation: "/%original_path%/%file_name%.%locale%.%file_extension%"
    # Tag uploaded strings so they're easy to filter in Crowdin.
    labels:
      - docs
    # Rewrite Crowdin's language ids onto the codes mkdocs-material ships
    # (so its UI strings resolve). pt-BR / ja / zh-TW pass through unchanged.
    languages_mapping:
      locale:
        es-ES: es
        es-419: es
        zh-CN: zh
