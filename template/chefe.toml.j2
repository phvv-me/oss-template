[workspace]
name = "{{ project_slug }}"
version = "0.0.1"
platforms = ["osx-arm64", "linux-64"]
channels = ["conda-forge"]

[deps]
python = ">={{ min_python }}"

[pypi.deps]
# chefe compiles this manifest into `.chefe/pixi.toml`, so pixi resolves relative
# paths from `.chefe/`; `..` points back at the project root holding `pyproject.toml`.
{{ package_name }} = { path = "..", editable = true }
ruff = "*"
pyrefly = "*"
mypy = "*"
pytest = "*"
pytest-cov = "*"
hypothesis = "*"
syrupy = "*"
pytest-subprocess = "*"
pytest-mock = "*"
faker = "*"
dirty-equals = "*"
mkdocs-material = "*"
mkdocs-llmstxt = "*"
mkdocs-static-i18n = "*"

# Tasks run from `.chefe/` (where the compiled pixi.toml lives), so `dir = ".."`
# points each one at the project root that holds `pyproject.toml`, `src/`, and `tests/`.
[tasks]
lint = { run = "ruff check . && ruff format --check .", dir = ".." }
typecheck = { run = "pyrefly check && mypy src", dir = ".." }
test = { run = "pytest -q", dir = ".." }
docs = { run = "mkdocs build -d site", dir = ".." }
