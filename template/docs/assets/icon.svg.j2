{% set gradients = {
  'amber': {'light': '#fbbf24', 'dark': '#d97706'},
  'blue': {'light': '#3b82f6', 'dark': '#1d4ed8'},
  'teal': {'light': '#2dd4bf', 'dark': '#0f766e'},
  'green': {'light': '#34d399', 'dark': '#047857'},
} %}
{% set gradient = gradients.get(accent_color, gradients['amber']) %}
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" role="img" aria-label="{{ project_name }}">
  <title>{{ project_name }}</title>
  <defs>
    <linearGradient id="brand" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="{{ gradient['light'] }}"/>
      <stop offset="1" stop-color="{{ gradient['dark'] }}"/>
    </linearGradient>
  </defs>
  <rect width="64" height="64" rx="15" fill="url(#brand)"/>
  <text x="32" y="34" fill="#ffffff" font-family="'Space Grotesk', system-ui, sans-serif"
        font-size="38" font-weight="700" text-anchor="middle" dominant-baseline="central">{{ project_name[0] | lower }}</text>
</svg>
