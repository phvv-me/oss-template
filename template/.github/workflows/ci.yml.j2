name: CI

on:
  pull_request:
  workflow_call: # publish.yml runs this exact gate on main before publishing

jobs:
  check:
    runs-on: {{ "${{ matrix.os }}" }}
    strategy:
      fail-fast: false
      matrix:
        os: [{{ ci_os }}]
    steps:
      - uses: actions/checkout@v4
      - name: Install chefe
        run: pip install chefe
      - name: Provision
        run: chefe install
      - name: Lint
        run: chefe run lint
      - name: Typecheck
        run: chefe run typecheck
      - name: Test
        run: chefe run test
