name: Docs

on:
  push:
    branches: [main]
    paths: ["docs/**", "mkdocs.yml", "README.md", "llms.txt", ".github/workflows/docs.yml"]
  workflow_dispatch:

permissions:
  contents: read
  pages: write
  id-token: write

concurrency:
  group: pages
  cancel-in-progress: false

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: astral-sh/setup-uv@v5
      - name: Build docs
        run: uvx --with mkdocs-material --with mkdocs-llmstxt mkdocs build -d site
      - uses: actions/upload-pages-artifact@v3
        with:
          path: site

  deploy:
    needs: build
    runs-on: ubuntu-latest
    environment:
      name: github-pages
      url: {{ "${{ steps.deployment.outputs.page_url }}" }}
    steps:
      - id: deployment
        uses: actions/deploy-pages@v4
