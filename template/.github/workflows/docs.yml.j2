name: Docs

# Deploys on main when docs change. The mkdocs build is the gate. (CI runs only
# on pull_request and workflow_call, so a workflow_run trigger would never fire.)
on:
  push:
    branches: [main]
    paths: ["docs/**", "mkdocs.yml", ".github/workflows/docs.yml", "README.md"]
  workflow_dispatch:

permissions:
  contents: read
  pages: write
  id-token: write

concurrency:
  group: pages
  cancel-in-progress: false

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v6
      - uses: astral-sh/setup-uv@v7
      - run: uv run --extra docs mkdocs build -d site
      - uses: actions/upload-pages-artifact@v5
        with:
          path: site

  deploy:
    needs: build
    runs-on: ubuntu-latest
    environment:
      name: github-pages
      url: {{ "${{ steps.deployment.outputs.page_url }}" }}
    steps:
      - id: deployment
        uses: actions/deploy-pages@v5
