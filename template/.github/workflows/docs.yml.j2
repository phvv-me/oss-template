name: Docs

# Deploys only after CI succeeds on main, so a failing CI never ships docs.
on:
  workflow_run:
    workflows: ["CI"]
    types: [completed]
    branches: [main]
  workflow_dispatch:

permissions:
  contents: read
  pages: write
  id-token: write

concurrency:
  group: pages
  cancel-in-progress: false

jobs:
  build:
    if: {{ "${{ github.event_name == 'workflow_dispatch' || github.event.workflow_run.conclusion == 'success' }}" }}
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Install chefe
        run: pip install chefe
      - name: Build docs
        run: chefe install && chefe run docs
      - uses: actions/upload-pages-artifact@v5
        with:
          path: site

  deploy:
    needs: build
    runs-on: ubuntu-latest
    environment:
      name: github-pages
      url: {{ "${{ steps.deployment.outputs.page_url }}" }}
    steps:
      - id: deployment
        uses: actions/deploy-pages@v5
