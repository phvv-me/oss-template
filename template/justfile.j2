default:
    @just --list

install:
    uv sync --extra dev --extra docs

lint:
    uv run ruff check . && uv run ruff format --check .

typecheck:
    uv run pyrefly check && uv run mypy src

test:
    uv run pytest -q

build:
    uv build

docs:
    uvx --with mkdocs-material --with mkdocs-llmstxt mkdocs build -d site
