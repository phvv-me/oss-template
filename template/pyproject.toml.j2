[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
name = "{{ package_name }}"
version = "0.0.1"
description = "{{ description }}"
readme = "README.md"
requires-python = ">={{ min_python }}"
license = "{{ license_spdx }}"
authors = [{ name = "{{ author_name }}", email = "{{ author_email }}" }]
classifiers = [
  "Development Status :: 3 - Alpha",
  "Intended Audience :: Developers",
  "Topic :: Software Development :: Libraries",
]
dependencies = [
  # project runtime deps go here
{% if cli_command %}
  "cyclopts>=4",
{% endif %}
]
{% if cli_command %}

[project.scripts]
{{ cli_command }} = "{{ module_name }}.cli:app"
{% endif %}

[project.urls]
Homepage = "{{ homepage_url }}"
Repository = "https://github.com/{{ github_owner }}/{{ repository_name }}"
Issues = "https://github.com/{{ github_owner }}/{{ repository_name }}/issues"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ module_name }}"]

[tool.ruff]
line-length = 99
target-version = "py{{ min_python | replace('.', '') }}"
extend-exclude = [".chefe"]

[tool.ruff.lint]
select = ["E", "F", "I", "UP", "B", "SIM"]

[tool.mypy]
python_version = "{{ min_python }}"
strict = true
disallow_any_explicit = true
files = ["src"]

[tool.pytest.ini_options]
addopts = "-q -ra --strict-markers"
testpaths = ["tests"]

[tool.coverage.run]
source = ["{{ module_name }}"]
branch = true

[tool.coverage.report]
show_missing = true
exclude_lines = [
  "pragma: no cover",
  "raise NotImplementedError",
  "if TYPE_CHECKING:",
  "if __name__ == .__main__.:",
]
