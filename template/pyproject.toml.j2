[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
name = "{{ package_name }}"
version = "0.0.1"
description = "{{ description }}"
readme = "README.md"
requires-python = ">={{ min_python }}"
license = "{{ license_spdx }}"
authors = [{ name = "{{ author_name }}", email = "{{ author_email }}" }]
keywords = [
  "{{ project_slug }}",
  # add discovery keywords users would search for
]
classifiers = [
  "Development Status :: 3 - Alpha",
  "Intended Audience :: Developers",
{% if license_spdx == 'Apache-2.0' %}
  "License :: OSI Approved :: Apache Software License",
{% elif license_spdx == 'MIT' %}
  "License :: OSI Approved :: MIT License",
{% endif %}
  "Programming Language :: Python :: 3",
{% for py in python_versions.replace('"', '').split(',') %}
  "Programming Language :: Python :: {{ py | trim }}",
{% endfor %}
  "Topic :: Software Development :: Libraries",
]
dependencies = [
  # project runtime deps go here
{% if cli_command %}
  "cyclopts>=4",
{% endif %}
]

[project.optional-dependencies]
dev = [
  "ruff>=0.6",
  "pyrefly>=1",
  "mypy>=1.11",
  "pytest>=8",
  "hypothesis>=6.100",
  "pytest-cov>=5",
  "syrupy>=4",
  "pytest-subprocess>=1.5",
  "pytest-mock>=3.14",
  "faker>=30",
  "dirty-equals>=0.8",
]
docs = ["mkdocs-material>=9.5", "mkdocs-static-i18n>=1.2"]
{% if cli_command %}

[project.scripts]
{{ cli_command }} = "{{ module_name }}.cli:app"
{% endif %}

[project.urls]
Homepage = "{{ homepage_url }}"
Documentation = "{{ docs_url }}"
Repository = "https://github.com/{{ github_owner }}/{{ repository_name }}"
Issues = "https://github.com/{{ github_owner }}/{{ repository_name }}/issues"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ module_name }}"]

[tool.ruff]
line-length = 99
target-version = "py{{ min_python | replace('.', '') }}"

[tool.ruff.lint]
select = ["E", "F", "I", "UP", "B", "SIM"]

[tool.pyrefly]
project-includes = ["src", "tests"]
search-path = ["src", "."]

[tool.mypy]
python_version = "{{ min_python }}"
strict = true
disallow_any_explicit = true
files = ["src"]
mypy_path = "src"
namespace_packages = false

[tool.pytest.ini_options]
addopts = "-q -ra --strict-markers --cov={{ module_name }} --cov-report=term-missing"
testpaths = ["tests"]

[tool.coverage.run]
source = ["{{ module_name }}"]
branch = true

[tool.coverage.report]
show_missing = true
fail_under = 100
exclude_lines = [
  "pragma: no cover",
  "raise NotImplementedError",
  "if TYPE_CHECKING:",
  "if __name__ == .__main__.:",
  "\\.\\.\\.",
]
