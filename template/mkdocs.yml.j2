site_name: {{ project_name }}
site_description: {{ description }}
site_url: {{ docs_url }}/
repo_url: https://github.com/{{ github_owner }}/{{ repository_name }}
repo_name: {{ github_owner }}/{{ repository_name }}
copyright: {{ license_spdx }} - {{ author_name }}

theme:
  name: material
  logo: assets/logo.svg
  favicon: assets/logo.svg
  font:
    text: Inter
    code: JetBrains Mono
  icon:
    repo: fontawesome/brands/github
  palette:
    - media: "(prefers-color-scheme: light)"
      scheme: default
      primary: black
      accent: {{ accent_color }}
      toggle:
        icon: material/weather-night
        name: Dark mode
    - media: "(prefers-color-scheme: dark)"
      scheme: slate
      primary: black
      accent: {{ accent_color }}
      toggle:
        icon: material/weather-sunny
        name: Light mode
  features:
    - navigation.instant
    - navigation.tabs
    - navigation.top
    - content.code.copy
    - content.code.annotate
    - toc.integrate

extra_css:
  - stylesheets/extra.css

nav:
  - Home: index.md
  - API: api.md
  - Release: release.md

markdown_extensions:
  - admonition
  - attr_list
  - md_in_html
  - tables
  - toc:
      permalink: true
  - pymdownx.details
  - pymdownx.highlight:
      anchor_linenums: true
  - pymdownx.superfences:
      custom_fences:
        - name: mermaid
          class: mermaid
          format: !!python/name:pymdownx.superfences.fence_code_format
  - pymdownx.inlinehilite

plugins:
  - search
  - i18n:
      docs_structure: suffix
      reconfigure_material: true
      reconfigure_search: true
      fallback_to_default: true
      languages:
        - locale: en
          name: English
          default: true
        - locale: pt-BR
          name: Português (BR)
          build: true
        - locale: es
          name: Español (LatAm)
          build: true
        - locale: ja
          name: 日本語
          build: true
        - locale: zh
          name: 中文
          build: true
  - llmstxt:
      markdown_description: {{ description }}
      full_output: llms-full.txt
      sections:
        Usage:
          - index.md
        Reference:
          - api.md
          - release.md
